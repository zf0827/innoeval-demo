KG2API_BASE_URL=http://127.0.0.1:8000
KG2API_API_KEY=replace-me
KG2API_TIMEOUT=120

# Required for tasks 1, 2, 4, and 5.
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Required for task 1 only.
GROBID_BASE_URL=http://127.0.0.1:8070
OA_API_KEY=
OPENALEX_MAILTO=

# Optional for task 1 grounding. If omitted, OPENAI_BASE_URL is used to derive
# the chat completions URL automatically.
# GROUNDING_API_URL=https://api.openai.com/v1/chat/completions

# Task 1 local model paths are passed via --params-file or --params-json.
# See examples/task1_params.local.example.json.
